generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model collaborators {
  user_id     String     @db.Uuid
  document_id String     @db.Uuid
  role        role_enum?
  documents   documents  @relation(fields: [document_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_document")
  users       users      @relation(fields: [user_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_user")

  @@id([user_id, document_id])
}

model documents {
  id            String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  content       String?
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  updated_at    DateTime?       @db.Timestamptz(6)
  collaborators collaborators[]
}

model users {
  id            String          @id @default(dbgenerated("uuidv7()")) @db.Uuid
  name          String
  password      String
  email         String          @unique
  created_at    DateTime?       @default(now()) @db.Timestamptz(6)
  collaborators collaborators[]
}

enum role_enum {
  Owner
  Collaborator
  Reader
}
